# ======================================================================
# Development Dockerfile for Rails 8 Application
# Optimized for hot code reloading with volume mounts
# ======================================================================

FROM ruby:3.3-slim

WORKDIR /rails

# Install system dependencies
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libpq-dev \
      libvips \
      nodejs \
      npm \
      pkg-config \
      postgresql-client \
      redis-tools \
      && rm -rf /var/lib/apt/lists /var/cache/apt/archives

# Install foreman for Procfile.dev management
RUN gem install foreman

# Set development environment
ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle" \
    BINDING="0.0.0.0" \
    EDITOR="vim"

# Pre-install gems for caching (will be overlaid by volume mount)
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy package files and install JS deps
COPY package.json yarn.lock* package-lock.json* ./
RUN if [ -f yarn.lock ]; then yarn install; \
    elif [ -f package-lock.json ]; then npm install; \
    else npm install; fi

# Copy entrypoint
COPY bin/docker-entrypoint-dev /rails/bin/docker-entrypoint-dev
RUN chmod +x /rails/bin/docker-entrypoint-dev

ENTRYPOINT ["./bin/docker-entrypoint-dev"]

EXPOSE 3000

# Default command: start development server with Procfile.dev
CMD ["bin/dev"]
